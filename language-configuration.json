{
  "comments": {
    "lineComment": { "comment": "//" }
  },
  "brackets": [
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ],
    [
      "{",
      "}"
    ]
  ],
  "colorizedBracketPairs": [],
  "indentationRules": {
    "increaseIndentPattern": "^((?!\\/\\/).)*(\\{[^}\"'`]*|\\([^)\"'`]*|\\[[^\\]\"'`]*)$",
    "decreaseIndentPattern": "^((?!.*?\\/\\*).*\\*/)?\\s*[\\)\\}\\]].*$"
  },
  "onEnterRules": [
    {
      "beforeText": { "pattern": "<(?!(?:area|base|br|col|embed|hr|img|input|keygen|link|menuitem|meta|param|source|track|wbr))([_:\\w][_:\\w\\.\\-\\d]*)(?![^>]*/>)[^>]*>$" },
      "afterText": { "pattern": "^\\s*</([_:\\w][_:\\w\\.\\-\\d]*)\\s*>" },
      "action": { "indent": "indentOutdent" }
    }
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}", "notIn": ["string"] },
    { "open": "(", "close": ")", "notIn": ["string"] },
    { "open": "[", "close": "]", "notIn": ["string"] },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    // v1.0.2: prevent auto-closing of single quotes due to ObjectScript's negation operator
    // { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    // CACHE TAGS
    { "open": "#server(", "close": ")#" },
    { "open": "#call(", "close": ")#" },
    { "open": "#(", "close": ")#" },
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""],
    ["'", "'"]
  ]
}
